@page "/recipes"
@rendermode InteractiveServer
@inject RecipeApiClient RecipeApi
@inject NavigationManager NavigationManager

<PageTitle>Recipes</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Recipes</h1>
        <a href="/recipes/new" class="btn btn-primary">
            <span aria-hidden="true">+</span> Add Recipe
        </a>
    </div>

    <!-- Search bar -->
    <div class="mb-3">
        <div class="input-group">
            <input type="text"
                   class="form-control"
                   placeholder="Search by name, description or tag..."
                   @bind="searchTerm"
                   @bind:event="oninput"
                   @onkeyup="OnSearchKeyUp" />
            <button class="btn btn-outline-secondary" type="button" @onclick="LoadRecipes">
                Search
            </button>
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                    Clear
                </button>
            }
        </div>
    </div>

    <!-- Category filter pills -->
    <div class="mb-3 d-flex flex-wrap gap-2">
        <button class="btn btn-sm @(selectedCategory == null ? "btn-primary" : "btn-outline-primary")"
                @onclick="() => SelectCategory(null)">
            All
        </button>
        @foreach (var cat in AllCategories)
        {
            var catCopy = cat;
            <button class="btn btn-sm @(selectedCategory == catCopy.ToString() ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => SelectCategory(catCopy.ToString())">
                @catCopy
            </button>
        }
    </div>

    <!-- States -->
    @if (isLoading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> @errorMessage
            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="LoadRecipes">Retry</button>
        </div>
    }
    else if (recipes.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <p class="fs-5">No recipes found.</p>
            @if (!string.IsNullOrEmpty(searchTerm) || selectedCategory != null)
            {
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearFilters">Clear filters</button>
            }
            else
            {
                <a href="/recipes/new" class="btn btn-primary btn-sm">Add your first recipe</a>
            }
        </div>
    }
    else
    {
        <!-- Recipe grid -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
            @foreach (var recipe in recipes)
            {
                var recipeCopy = recipe;
                <div class="col">
                    <div class="card h-100 shadow-sm recipe-card" style="cursor:pointer"
                         @onclick="() => GoToRecipe(recipeCopy.Id)">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h5 class="card-title mb-0">@recipeCopy.Name</h5>
                                <span class="badge @GetCategoryBadgeClass(recipeCopy.Category) ms-2 text-nowrap">
                                    @recipeCopy.Category
                                </span>
                            </div>

                            @if (!string.IsNullOrEmpty(recipeCopy.Description))
                            {
                                <p class="card-text text-muted small mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                    @recipeCopy.Description
                                </p>
                            }

                            <div class="d-flex flex-wrap gap-3 text-muted small mb-2">
                                @if (recipeCopy.PrepTimeMinutes.HasValue || recipeCopy.CookTimeMinutes.HasValue)
                                {
                                    <span title="Total time">
                                        <span aria-hidden="true">&#8987;</span>
                                        @FormatTime(recipeCopy.PrepTimeMinutes, recipeCopy.CookTimeMinutes)
                                    </span>
                                }
                                <span title="Servings">
                                    <span aria-hidden="true">&#128101;</span>
                                    @recipeCopy.Servings serving@(recipeCopy.Servings != 1 ? "s" : "")
                                </span>
                            </div>

                            @if (recipeCopy.Tags.Count > 0)
                            {
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var tag in recipeCopy.Tags.Take(5))
                                    {
                                        <span class="badge bg-light text-dark border">@tag</span>
                                    }
                                    @if (recipeCopy.Tags.Count > 5)
                                    {
                                        <span class="badge bg-light text-muted border">+@(recipeCopy.Tags.Count - 5)</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="d-flex justify-content-between align-items-center mt-4">
            <span class="text-muted small">
                Page @currentPage
                @if (recipes.Count > 0)
                {
                    <text> &mdash; showing @recipes.Count recipe@(recipes.Count != 1 ? "s" : "")</text>
                }
            </span>
            <div class="btn-group" role="group" aria-label="Pagination">
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="PreviousPage"
                        disabled="@(currentPage <= 1)">
                    &laquo; Previous
                </button>
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="NextPage"
                        disabled="@(recipes.Count < pageSize)">
                    Next &raquo;
                </button>
            </div>
        </div>
    }
</div>

@code {
    private List<RecipeResponse> recipes = [];
    private bool isLoading = true;
    private string? errorMessage;
    private string? searchTerm;
    private string? selectedCategory;
    private int currentPage = 1;
    private const int pageSize = 20;

    private static readonly RecipeCategory[] AllCategories = Enum.GetValues<RecipeCategory>();

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipes();
    }

    private async Task LoadRecipes()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            recipes = await RecipeApi.GetRecipesAsync(
                search: string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm.Trim(),
                category: selectedCategory,
                page: currentPage,
                pageSize: pageSize);
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load recipes: {ex.Message}";
            recipes = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            currentPage = 1;
            await LoadRecipes();
        }
    }

    private async Task SelectCategory(string? category)
    {
        selectedCategory = category;
        currentPage = 1;
        await LoadRecipes();
    }

    private async Task ClearSearch()
    {
        searchTerm = null;
        currentPage = 1;
        await LoadRecipes();
    }

    private async Task ClearFilters()
    {
        searchTerm = null;
        selectedCategory = null;
        currentPage = 1;
        await LoadRecipes();
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadRecipes();
        }
    }

    private async Task NextPage()
    {
        if (recipes.Count >= pageSize)
        {
            currentPage++;
            await LoadRecipes();
        }
    }

    private static string FormatTime(int? prep, int? cook)
    {
        var total = (prep ?? 0) + (cook ?? 0);
        if (total == 0) return "—";
        if (total < 60) return $"{total} min";
        var h = total / 60;
        var m = total % 60;
        return m == 0 ? $"{h}h" : $"{h}h {m}m";
    }

    private void GoToRecipe(Guid id) => NavigationManager.NavigateTo($"/recipes/{id}");

    private static string GetCategoryBadgeClass(RecipeCategory category) => category switch
    {
        RecipeCategory.Breakfast => "bg-warning text-dark",
        RecipeCategory.Lunch     => "bg-info text-dark",
        RecipeCategory.Dinner    => "bg-primary",
        RecipeCategory.Snack     => "bg-success",
        RecipeCategory.Dessert   => "bg-danger",
        RecipeCategory.Side      => "bg-secondary",
        RecipeCategory.Drink     => "bg-dark",
        _                        => "bg-secondary"
    };
}
